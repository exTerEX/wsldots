# Export environment variables and WSL-specific settings
export LANG="en_US.UTF-8"
export LC_ALL="en_US.UTF-8"

if [ -r /proc/sys/kernel/osrelease ] && grep -qi microsoft /proc/sys/kernel/osrelease 2>/dev/null; then
    if [ -r /etc/resolv.conf ]; then
        export DISPLAY="$(grep -m1 nameserver /etc/resolv.conf | awk '{print $2}'):0.0"
    fi
    export LIBGL_ALWAYS_INDIRECT=1
fi
